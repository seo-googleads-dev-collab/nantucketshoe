# Server
HOST=0.0.0.0
PORT=1337

# Secrets — generate your own with `openssl rand -base64 16` (one value per line)
APP_KEYS=key1==,key2==,key3==,key4==
API_TOKEN_SALT=replace-me
ADMIN_JWT_SECRET=replace-me
TRANSFER_TOKEN_SALT=replace-me
JWT_SECRET=replace-me
ENCRYPTION_KEY=replace-me

# Database (matches docker-compose.yml — do not change for local dev)
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false
DATABASE_FILENAME=
